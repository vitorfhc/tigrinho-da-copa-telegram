# TigrinhoDaCopa — SECRETS ONLY (COMPLETION.md §4.1).
# Copy to `.env` and fill these in. NEVER commit the real `.env`.
# Every non-secret setting lives in `config.yaml` (see `config.example.yaml`).

# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# API-Football API key.
API_FOOTBALL_KEY=

# Optional: Google Gemini API key. Enables the AI /palpite feature (§20). Leave blank to disable
# (then /palpite reports that no key is configured and the daily generation job is skipped).
GEMINI_API_KEY=

# Optional: path to the non-secret settings file (default ./config.yaml).
# This is the ONLY non-secret value allowed in the environment.
# CONFIG_PATH=./config.yaml
